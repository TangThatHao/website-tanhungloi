<%- include('partials/header', { pageTitle: 'Đặt hàng - Tân Hưng Lợi', activeNav: '' }) %>

<div class="container">
  <div class="breadcrumb"><a href="/">Trang chủ</a> / <a href="/gio-hang">Giỏ hàng</a> / Đặt hàng</div>
  <div class="section-title">Thông tin giao hàng</div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <div class="page-body no-right">
    <main>
      <div class="box">
        <div class="box-body">
          <form action="/thanh-toan" method="post">
            <div class="field"><label>Họ tên người nhận</label><input type="text" name="customer_name" value="<%= form.customer_name || (currentUser ? currentUser.full_name : '') || '' %>" required /></div>
            <div class="field"><label>Số điện thoại</label><input type="text" name="phone" value="<%= form.phone || (currentUser ? currentUser.phone : '') || '' %>" required /></div>
            <div class="field"><label>Email</label><input type="email" name="email" value="<%= form.email || (currentUser ? currentUser.email : '') || '' %>" /></div>
            <div class="field"><label>Địa chỉ giao hàng</label><textarea name="address" rows="3" required><%= form.address || '' %></textarea></div>
            <div class="field"><label>Ghi chú</label><textarea name="note" rows="2"><%= form.note || '' %></textarea></div>
            <button type="submit" class="btn btn-primary btn-block">Xác nhận đặt hàng</button>
          </form>
        </div>
      </div>
    </main>

    <aside>
      <div class="box">
        <div class="box-title">ĐƠN HÀNG CỦA BẠN</div>
        <div class="box-body">
          <% items.forEach(item => { %>
            <div class="mini-product">
              <img src="<%= item.product.image %>" alt="<%= item.product.name %>" />
              <div>
                <div class="name"><%= item.product.name %> x<%= item.qty %></div>
                <div class="price"><%= formatPrice(item.lineTotal) %></div>
              </div>
            </div>
          <% }) %>
          <div class="row total" style="display:flex; justify-content:space-between; margin-top:10px;">
            <span>Tổng cộng</span><span><%= formatPrice(total) %></span>
          </div>
        </div>
      </div>
    </aside>
  </div>
</div>

<%- include('partials/footer') %>
