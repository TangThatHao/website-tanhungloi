<%- include('partials/header', { pageTitle: 'Giỏ hàng - Tân Hưng Lợi', activeNav: '' }) %>

<div class="container">
  <div class="breadcrumb"><a href="/">Trang chủ</a> / Giỏ hàng</div>
  <div class="section-title">Giỏ hàng của bạn</div>

  <% if (items.length === 0) { %>
    <div class="empty-state">
      <p>Giỏ hàng của bạn đang trống.</p>
      <a href="/san-pham" class="btn btn-primary">Tiếp tục mua sắm</a>
    </div>
  <% } else { %>
    <form action="/gio-hang/cap-nhat" method="post">
      <table class="cart-table">
        <thead>
          <tr><th>Sản phẩm</th><th>Đơn giá</th><th>Số lượng</th><th>Thành tiền</th><th></th></tr>
        </thead>
        <tbody>
          <% items.forEach(item => { %>
            <tr>
              <td class="prod-cell">
                <img src="<%= item.product.image %>" alt="<%= item.product.name %>" />
                <a href="/san-pham/<%= item.product.slug %>"><%= item.product.name %></a>
              </td>
              <td><%= formatPrice(item.product.price) %></td>
              <td><input type="number" class="cart-qty-input" data-price="<%= item.product.price %>" name="qty[<%= item.product.id %>]" value="<%= item.qty %>" min="1" /></td>
              <td class="line-total"><%= formatPrice(item.lineTotal) %></td>
              <td>
                <form action="/gio-hang/xoa" method="post">
                  <input type="hidden" name="productId" value="<%= item.product.id %>" />
                  <button type="submit" class="btn btn-outline btn-sm">Xóa</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <div style="margin-top:12px;">
        <button type="submit" class="btn btn-outline">Cập nhật giỏ hàng</button>
        <a href="/san-pham" class="btn btn-outline">Tiếp tục mua sắm</a>
      </div>
    </form>

    <div class="cart-summary">
      <div class="box">
        <div class="box-body">
          <div class="row"><span>Tạm tính</span><span id="cartSubtotal"><%= formatPrice(total) %></span></div>
          <div class="row total"><span>Tổng cộng</span><span id="cartTotal"><%= formatPrice(total) %></span></div>
          <a href="/thanh-toan" class="btn btn-primary btn-block" style="margin-top:10px;">Tiến hành đặt hàng</a>
        </div>
      </div>
    </div>
  <% } %>
</div>

<script>
(function () {
  function formatPrice(n) {
    return Number(n || 0).toLocaleString('vi-VN') + ' VNĐ';
  }
  var qtyInputs = document.querySelectorAll('.cart-qty-input');
  var subtotalEl = document.getElementById('cartSubtotal');
  var totalEl = document.getElementById('cartTotal');

  function recalc() {
    var subtotal = 0;
    qtyInputs.forEach(function (input) {
      var price = Number(input.getAttribute('data-price')) || 0;
      var qty = Math.max(1, parseInt(input.value, 10) || 1);
      var lineTotal = price * qty;
      subtotal += lineTotal;
      var row = input.closest('tr');
      if (row) {
        var cell = row.querySelector('.line-total');
        if (cell) cell.textContent = formatPrice(lineTotal);
      }
    });
    if (subtotalEl) subtotalEl.textContent = formatPrice(subtotal);
    if (totalEl) totalEl.textContent = formatPrice(subtotal);
  }

  qtyInputs.forEach(function (input) {
    input.addEventListener('input', recalc);
    input.addEventListener('change', recalc);
  });
})();
</script>

<%- include('partials/footer') %>
