<div class="box">
  <div class="box-title">🌏 SẢN PHẨM XUẤT KHẨU <a href="/san-pham?label=export" class="view-all-link">Xem tất cả →</a></div>
  <div class="box-body">
    <% sidebarExportProducts.forEach(p => { %>
      <a href="/san-pham/<%= p.slug %>" class="mini-product">
        <img src="<%= p.image %>" alt="<%= p.name %>" />
        <div>
          <div class="price"><%= formatPrice(p.price) %></div>
          <div class="name"><%= p.name %></div>
        </div>
      </a>
    <% }) %>
  </div>
</div>

