<%- include('partials/header', { pageTitle: product.name + ' - Tân Hưng Lợi', activeNav: 'products' }) %>

<div class="container">
  <div class="breadcrumb"><a href="/">Trang chủ</a> / <a href="/san-pham">Sản phẩm</a> / <%= product.name %></div>
  <div class="page-body no-right">
    <aside><%- include('partials/sidebar-left') %></aside>

    <main>
      <div class="box">
        <div class="box-body">
          <div class="product-detail">
            <div class="gallery" data-gallery='<%= JSON.stringify(gallery) %>'>
              <div class="gallery-main">
                <img id="mainProductImage" src="<%= gallery[0] %>" alt="<%= product.name %>" data-index="0" />
                <button type="button" class="gallery-zoom-hint" aria-label="Xem ảnh lớn">🔍</button>
              </div>
              <% if (gallery.length > 1) { %>
              <div class="gallery-thumbs">
                <% gallery.forEach((img, i) => { %>
                  <img class="gallery-thumb<%= i === 0 ? ' active' : '' %>" src="<%= img %>" data-index="<%= i %>" alt="<%= product.name %> - ảnh <%= i + 1 %>" />
                <% }) %>
              </div>
              <% } %>
            </div>
            <div>
              <h1><%= product.name %></h1>
              <div class="price-lg"><%= formatPrice(product.price) %></div>
              <% if (successMsg) { %><div class="alert alert-success"><%= successMsg %></div><% } %>
              <form action="/gio-hang/them" method="post">
                <input type="hidden" name="productId" value="<%= product.id %>" />
                <input type="hidden" name="redirectTo" value="/san-pham/<%= product.slug %>" />
                <div class="qty-box">
                  <label for="qty">Số lượng:</label>
                  <input type="number" id="qty" name="qty" value="1" min="1" />
                </div>
                <button type="submit" class="btn btn-primary">Thêm vào giỏ hàng</button>
                <a href="/gio-hang" class="btn btn-outline">Xem giỏ hàng</a>
              </form>
              <div class="desc-block">
                <h3>Mô tả sản phẩm</h3>
                <p class="desc-text"><%= product.description %></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <% if (related.length) { %>
        <div class="section-title" style="margin-top:24px;">Sản phẩm liên quan</div>
        <div class="product-grid">
          <% related.forEach(p => { %><%- include('partials/product-card', { p, currentPath: '/san-pham/' + product.slug }) %><% }) %>
        </div>
      <% } %>
    </main>
  </div>
</div>

<div id="lightboxOverlay" class="lightbox-overlay">
  <button type="button" class="lightbox-close" aria-label="Đóng">&times;</button>
  <button type="button" class="lightbox-nav lightbox-prev" aria-label="Ảnh trước">&#8249;</button>
  <div class="lightbox-viewport">
    <img id="lightboxImg" src="" alt="" draggable="false" />
  </div>
  <button type="button" class="lightbox-nav lightbox-next" aria-label="Ảnh sau">&#8250;</button>
  <div class="lightbox-counter"><span id="lightboxCounter"></span></div>
  <div class="lightbox-hint">Cuộn để zoom · Kéo để di chuyển · Nháy đúp để phóng to</div>
</div>

<%- include('partials/footer') %>
