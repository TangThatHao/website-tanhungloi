<%- include('partials/header', { pageTitle: (activeCategory ? categoryName + ' - ' : '') + 'Sản phẩm - Tân Hưng Lợi', activeNav: 'products', searchQuery }) %>

<div class="container">
  <div class="breadcrumb" id="productsBreadcrumb"><a href="/">Trang chủ</a> / <a href="/san-pham">Sản phẩm</a><% if (categoryName) { %> / <span id="breadcrumbExtra"><%= categoryName %></span><% } %></div>
  <div class="page-body">
    <aside><%- include('partials/sidebar-left', { activeCategory }) %></aside>

    <main>
      <div class="category-chips" id="categoryChips">
        <a href="/san-pham" class="<%= !activeCategory ? 'active' : '' %>">Tất cả</a>
        <% navCategories.forEach(cat => { %>
          <a href="/san-pham?category=<%= cat.slug %>" class="<%= activeCategory === cat.slug ? 'active' : '' %>"><%= cat.name %></a>
        <% }) %>
      </div>
      <div id="productResults">
        <%- include('partials/product-results', { products, categoryName, searchQuery }) %>
      </div>
    </main>

    <aside><%- include('partials/sidebar-right') %></aside>
  </div>
</div>

<%- include('partials/footer') %>
