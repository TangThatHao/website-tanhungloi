<%- include('partials/layout-header', { pageTitle: product ? 'Sửa sản phẩm' : 'Thêm sản phẩm', activeAdminNav: 'products' }) %>

<div class="admin-card" style="max-width:640px;">
  <h3 style="margin-top:0;"><%= product ? 'Sửa sản phẩm' : 'Thêm sản phẩm mới' %></h3>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <form action="<%= product ? '/admin/san-pham/' + product.id + '/sua' : '/admin/san-pham/them' %>" method="post" enctype="multipart/form-data">
    <div class="field"><label>Tên sản phẩm</label><input type="text" name="name" value="<%= product ? product.name : '' %>" required /></div>
    <div class="field">
      <label>Danh mục</label>
      <select name="category_id" required>
        <% categories.forEach(c => { %>
          <option value="<%= c.id %>" <%= product && product.category_id === c.id ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="field"><label>Giá (VNĐ, để trống nếu "Liên hệ")</label><input type="number" name="price" value="<%= product && product.price !== null ? product.price : '' %>" /></div>
    <div class="field">
      <label>Ảnh đại diện (tải file lên để thay thế)</label>
      <input type="file" name="image_file" accept="image/*" />
      <% if (product && product.image) { %>
        <div style="margin-top:8px;">
          <img src="<%= product.image %>" style="width:80px; display:block; border-radius:6px; margin-bottom:4px;" />
          <label style="font-size:12px; color:var(--color-muted); font-weight:400;"><input type="checkbox" name="delete_image" value="1" style="width:auto;" /> Xóa ảnh đại diện hiện tại</label>
        </div>
      <% } %>
    </div>
    <div class="field"><label>Hoặc dán URL ảnh</label><input type="text" name="image_url" placeholder="/images/products/... hoặc https://..." /></div>
    <div class="field">
      <label>Ảnh bổ sung (có thể chọn nhiều ảnh cùng lúc)</label>
      <input type="file" name="gallery_files" accept="image/*" multiple />
      <% if (galleryImages && galleryImages.length) { %>
        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:10px;">
          <% galleryImages.forEach(g => { %>
            <label style="text-align:center; font-size:11px; color:var(--color-muted);">
              <img src="<%= g.image %>" style="width:70px; height:70px; object-fit:cover; border-radius:6px; display:block; margin-bottom:4px;" />
              <input type="checkbox" name="delete_images" value="<%= g.id %>" style="width:auto;" /> Xóa
            </label>
          <% }) %>
        </div>
      <% } %>
    </div>
    <div class="field"><label>Mô tả</label><textarea name="description" rows="4"><%= product ? product.description : '' %></textarea></div>
    <div class="field">
      <label><input type="checkbox" name="is_hot" <%= product && product.is_hot ? 'checked' : '' %> style="width:auto;" /> Sản phẩm HOT</label>
    </div>
    <div class="field">
      <label><input type="checkbox" name="is_new" <%= product && product.is_new ? 'checked' : '' %> style="width:auto;" /> Sản phẩm mới</label>
    </div>
    <div class="field">
      <label><input type="checkbox" name="is_export" <%= product && product.is_export ? 'checked' : '' %> style="width:auto;" /> Sản phẩm xuất khẩu</label>
    </div>
    <button type="submit" class="btn btn-primary">Lưu sản phẩm</button>
    <a href="/admin/san-pham" class="btn btn-outline">Hủy</a>
  </form>
</div>

<%- include('partials/layout-footer') %>
