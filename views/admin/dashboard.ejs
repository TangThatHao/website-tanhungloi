<%- include('partials/layout-header', { pageTitle: 'Tổng quan', activeAdminNav: 'dashboard' }) %>

<div class="stat-grid">
  <div class="stat-card"><div class="num"><%= stats.productCount %></div><div class="label">Sản phẩm</div></div>
  <div class="stat-card"><div class="num"><%= stats.orderCount %></div><div class="label">Đơn hàng</div></div>
  <div class="stat-card">
    <div class="num"><%= formatPrice(stats.revenue) %></div>
    <div class="label">Doanh thu (hoàn thành)</div>
    <div style="font-size:11.5px; margin-top:4px; font-weight:700; color:<%= revenueChangePct >= 0 ? '#3a8a4f' : 'var(--color-primary)' %>;">
      <%= revenueChangePct >= 0 ? '▲' : '▼' %> <%= Math.abs(revenueChangePct) %>% so với tháng trước
    </div>
  </div>
  <div class="stat-card"><div class="num"><%= stats.memberCount %></div><div class="label">Thành viên</div></div>
</div>

<% if (stats.unreadContacts > 0) { %>
  <a href="/admin/lien-he" class="admin-card" style="display:flex; align-items:center; justify-content:space-between; text-decoration:none; color:inherit;">
    <span>✉️ Bạn có <strong><%= stats.unreadContacts %></strong> tin nhắn liên hệ chưa đọc</span>
    <span class="view-all-link">Xem ngay →</span>
  </a>
<% } %>

<div class="admin-card">
  <h3 style="margin-top:0;">Doanh thu theo tháng (6 tháng gần nhất)</h3>
  <% const maxRevenue = Math.max(1, ...monthlyRevenue.map((m) => m.revenue)); %>
  <div class="bar-chart">
    <% monthlyRevenue.forEach((m) => { %>
      <div class="bar-chart-col">
        <div class="bar-chart-value"><%= m.revenue ? formatPrice(m.revenue) : '' %></div>
        <div class="bar-chart-bar" style="height: <%= Math.max(2, Math.round((m.revenue / maxRevenue) * 100)) %>%;"></div>
        <div class="bar-chart-label"><%= m.label %></div>
      </div>
    <% }) %>
  </div>
</div>

<div class="admin-card">
  <h3 style="margin-top:0;">⏳ Đơn hàng cần xử lý (<%= stats.pendingOrdersCount %>)</h3>
  <% if (pendingOrders.length === 0) { %>
    <p style="color:var(--color-muted); font-size:13px; margin:0;">🎉 Không có đơn nào cần xử lý.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>Mã</th><th>Khách hàng</th><th>Điện thoại</th><th>Tổng tiền</th><th>Trạng thái</th><th>Ngày đặt</th></tr></thead>
      <tbody>
        <% pendingOrders.forEach(o => { %>
          <tr>
            <td><a href="/admin/don-hang/<%= o.id %>">#<%= o.id %></a></td>
            <td><%= o.customer_name %></td>
            <td><%= o.phone %></td>
            <td><%= formatPrice(o.total) %></td>
            <td><span class="status-pill status-<%= o.status %>"><%= ({moi:'Mới', dang_xu_ly:'Đang xử lý'})[o.status] %></span></td>
            <td><%= new Date(o.created_at).toLocaleString('vi-VN') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <% if (stats.pendingOrdersCount > pendingOrders.length) { %>
      <div style="margin-top:10px;"><a href="/admin/don-hang" class="view-all-link">Xem tất cả đơn hàng →</a></div>
    <% } %>
  <% } %>
</div>

<div class="admin-card">
  <h3 style="margin-top:0;">🏆 Sản phẩm bán chạy nhất</h3>
  <% if (topProducts.length === 0) { %>
    <p style="color:var(--color-muted); font-size:13px; margin:0;">Chưa có đơn hàng hoàn thành nào.</p>
  <% } else { %>
    <% topProducts.forEach(p => { %>
      <div class="mini-product">
        <img src="<%= p.image || '/images/logo.jpg' %>" alt="" />
        <div>
          <div class="name"><%= p.product_name %></div>
          <div class="price"><%= p.qty_sold %> đã bán</div>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<div class="admin-card">
  <h3 style="margin-top:0;">Đơn hàng gần đây</h3>
  <table class="admin-table">
    <thead><tr><th>Mã</th><th>Khách hàng</th><th>Điện thoại</th><th>Tổng tiền</th><th>Trạng thái</th><th>Ngày đặt</th></tr></thead>
    <tbody>
      <% recentOrders.forEach(o => { %>
        <tr>
          <td><a href="/admin/don-hang/<%= o.id %>">#<%= o.id %></a></td>
          <td><%= o.customer_name %></td>
          <td><%= o.phone %></td>
          <td><%= formatPrice(o.total) %></td>
          <td><span class="status-pill status-<%= o.status %>"><%= ({moi:'Mới', dang_xu_ly:'Đang xử lý', hoan_thanh:'Hoàn thành', huy:'Đã hủy'})[o.status] %></span></td>
          <td><%= new Date(o.created_at).toLocaleString('vi-VN') %></td>
        </tr>
      <% }) %>
      <% if (recentOrders.length === 0) { %><tr><td colspan="6">Chưa có đơn hàng.</td></tr><% } %>
    </tbody>
  </table>
</div>

<%- include('partials/layout-footer') %>
