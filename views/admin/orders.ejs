<%- include('partials/layout-header', { pageTitle: 'Đơn hàng', activeAdminNav: 'orders' }) %>

<div class="admin-card">
  <h3 style="margin-top:0;">Danh sách đơn hàng (<%= orders.length %>)</h3>
  <table class="admin-table">
    <thead><tr><th>Mã</th><th>Khách hàng</th><th>Điện thoại</th><th>Tổng tiền</th><th>Trạng thái</th><th>Ngày đặt</th><th></th></tr></thead>
    <tbody>
      <% orders.forEach(o => { %>
        <tr>
          <td>#<%= o.id %></td>
          <td><%= o.customer_name %></td>
          <td><%= o.phone %></td>
          <td><%= formatPrice(o.total) %></td>
          <td><span class="status-pill status-<%= o.status %>"><%= ({moi:'Mới', dang_xu_ly:'Đang xử lý', hoan_thanh:'Hoàn thành', huy:'Đã hủy'})[o.status] %></span></td>
          <td><%= new Date(o.created_at).toLocaleString('vi-VN') %></td>
          <td><a href="/admin/don-hang/<%= o.id %>" class="btn btn-outline btn-sm">Chi tiết</a></td>
        </tr>
      <% }) %>
      <% if (orders.length === 0) { %><tr><td colspan="7">Chưa có đơn hàng.</td></tr><% } %>
    </tbody>
  </table>
</div>

<%- include('partials/layout-footer') %>
