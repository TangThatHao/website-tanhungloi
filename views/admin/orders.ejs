<%- include('partials/layout-header', { pageTitle: 'Đơn hàng', activeAdminNav: 'orders' }) %>

<%
  const statusOrder = ['moi', 'dang_xu_ly', 'hoan_thanh', 'huy'];
  const statusLabels = { moi: 'Mới', dang_xu_ly: 'Đang xử lý', hoan_thanh: 'Hoàn thành', huy: 'Đã hủy' };
  const grouped = { moi: [], dang_xu_ly: [], hoan_thanh: [], huy: [] };
  orders.forEach(o => { (grouped[o.status] || (grouped[o.status] = [])).push(o); });
%>

<h2 style="margin-top:0;">Danh sách đơn hàng (<%= orders.length %>)</h2>

<% statusOrder.forEach(s => { %>
  <% if (grouped[s].length > 0) { %>
    <div class="admin-card" style="margin-bottom:20px;">
      <h3 style="margin-top:0;"><span class="status-pill status-<%= s %>"><%= statusLabels[s] %></span> (<%= grouped[s].length %>)</h3>
      <table class="admin-table">
        <thead><tr><th>Mã</th><th>Khách hàng</th><th>Điện thoại</th><th>Tổng tiền</th><th>Ngày đặt</th><th></th></tr></thead>
        <tbody>
          <% grouped[s].forEach(o => { %>
            <tr>
              <td>#<%= o.id %></td>
              <td><%= o.customer_name %></td>
              <td><%= o.phone %></td>
              <td><%= formatPrice(o.total) %></td>
              <td><%= new Date(o.created_at).toLocaleString('vi-VN') %></td>
              <td><a href="/admin/don-hang/<%= o.id %>" class="btn btn-outline btn-sm">Chi tiết</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
<% }) %>

<% if (orders.length === 0) { %>
  <div class="admin-card">Chưa có đơn hàng.</div>
<% } %>

<%- include('partials/layout-footer') %>
