<%- include('partials/layout-header', { pageTitle: 'Đổi mật khẩu', activeAdminNav: 'change-password' }) %>

<div class="admin-card" style="max-width:420px;">
  <h3 style="margin-top:0;">Đổi mật khẩu admin</h3>
  <% if (pending) { %>
    <p>Bạn đang đăng nhập bằng mật khẩu tạm được gửi qua email. Đổi sang mật khẩu dễ nhớ, hoặc bỏ qua để giữ nguyên mật khẩu ngẫu nhiên này.</p>
  <% } %>
  <% if (error) { %><p style="color:#c0392b;"><%= error %></p><% } %>
  <% if (success) { %><p style="color:#2e7d32;"><%= success %></p><% } %>
  <form method="post" action="/admin/doi-mat-khau">
    <div class="field">
      <label>Mật khẩu hiện tại</label>
      <input type="password" name="mat_khau_cu" required />
    </div>
    <div class="field">
      <label>Mật khẩu mới</label>
      <input type="password" name="mat_khau_moi" required minlength="6" />
    </div>
    <div class="field">
      <label>Nhập lại mật khẩu mới</label>
      <input type="password" name="mat_khau_moi_lai" required minlength="6" />
    </div>
    <button type="submit" class="btn btn-primary">Đổi mật khẩu</button>
  </form>
  <% if (pending) { %>
    <form method="post" action="/admin/doi-mat-khau/bo-qua" style="margin-top:10px;">
      <button type="submit" class="btn btn-outline btn-block">Bỏ qua, giữ mật khẩu ngẫu nhiên</button>
    </form>
  <% } %>
</div>

<%- include('partials/layout-footer') %>
