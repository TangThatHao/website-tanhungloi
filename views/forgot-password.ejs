<%- include('partials/header', { pageTitle: 'Quên mật khẩu - Tân Hưng Lợi', activeNav: '' }) %>

<div class="container">
  <div class="form-box">
    <h2>QUÊN MẬT KHẨU</h2>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (!success) { %>
      <p>Nhập tên đăng nhập hoặc email đã đăng ký, hệ thống sẽ gửi liên kết đặt lại mật khẩu tới email của bạn.</p>
      <form action="/quen-mat-khau" method="post">
        <div class="field"><label>Tên đăng nhập hoặc Email</label><input type="text" name="tai_khoan" required /></div>
        <button type="submit" class="btn btn-primary btn-block">Gửi liên kết đặt lại mật khẩu</button>
      </form>
    <% } %>
    <div class="form-alt"><a href="/dang-nhap">← Quay lại đăng nhập</a></div>
  </div>
</div>

<%- include('partials/footer') %>
