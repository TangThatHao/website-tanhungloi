<%- include('partials/header', { pageTitle: 'Bánh Pía Tân Hưng Lợi - Đặc sản Sóc Trăng', activeNav: 'home' }) %>

<div class="banner-slider" id="topBanner">
  <div class="slides">
    <% banners.forEach(src => { %><img src="<%= src %>" alt="Banner Tân Hưng Lợi" /><% }) %>
  </div>
  <div class="banner-dots">
    <% banners.forEach((src, i) => { %><span class="<%= i === 0 ? 'active' : '' %>" data-i="<%= i %>"></span><% }) %>
  </div>
</div>

<div class="container">
  <div class="page-body">
    <aside><%- include('partials/sidebar-left') %></aside>

    <main>
      <div class="section-title">🔥 Sản phẩm bán chạy</div>
      <div class="product-grid">
        <% bestSellers.forEach(p => { %><%- include('partials/product-card', { p, currentPath: '/' }) %><% }) %>
      </div>

      <div class="section-title" style="margin-top:24px;">✨ Sản phẩm mới</div>
      <div class="product-grid">
        <% newProducts.forEach(p => { %><%- include('partials/product-card', { p, currentPath: '/' }) %><% }) %>
      </div>

      <div class="section-title" style="margin-top:24px;">📰 Bài viết nổi bật</div>
      <div class="box">
        <div class="box-body">
          <% featuredNews.forEach(n => { %>
            <div class="news-list-item">
              <img src="<%= n.thumbnail %>" alt="<%= n.title %>" />
              <div>
                <h3><a href="/tin-tuc/<%= n.slug %>"><%= n.title %></a></h3>
                <p style="font-size:13px; color:var(--color-muted);"><%= n.summary %></p>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </main>

    <aside><%- include('partials/sidebar-right') %></aside>
  </div>
</div>

<%- include('partials/footer') %>
