<%- include('partials/header', { pageTitle: news.title + ' - Tân Hưng Lợi', activeNav: 'news' }) %>

<div class="container">
  <div class="breadcrumb"><a href="/">Trang chủ</a> / <a href="/tin-tuc">Tin tức</a> / <%= news.title %></div>
  <div class="page-body no-right">
    <aside><%- include('partials/sidebar-left') %></aside>

    <main>
      <div class="box">
        <div class="box-body content-page">
          <h1><%= news.title %></h1>
          <img src="<%= news.thumbnail %>" alt="<%= news.title %>" style="border-radius:8px; max-height:340px; object-fit:cover; width:100%;" />
          <div class="news-detail-content"><%= news.content %></div>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/footer') %>
