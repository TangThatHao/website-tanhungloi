<%- include('partials/header', { pageTitle: 'Đổi mật khẩu - Tân Hưng Lợi', activeNav: '' }) %>

<div class="container">
  <div class="breadcrumb"><a href="/">Trang chủ</a> / <a href="/tai-khoan">Tài khoản của tôi</a> / Đổi mật khẩu</div>
  <div class="account-layout" style="margin-bottom:40px;">
    <nav class="box account-nav">
      <a href="/tai-khoan">Thông tin tài khoản</a>
      <a href="/tai-khoan/doi-mat-khau" class="active">Đổi mật khẩu</a>
      <a href="/gio-hang">Giỏ hàng</a>
      <a href="/dang-xuat">Đăng xuất</a>
    </nav>

    <div>
      <div class="box">
        <div class="box-title">ĐỔI MẬT KHẨU</div>
        <div class="box-body">
          <% if (pending) { %>
            <div class="alert alert-success">Bạn đang đăng nhập bằng mật khẩu tạm được gửi qua email. Đổi sang mật khẩu dễ nhớ, hoặc bỏ qua để giữ nguyên mật khẩu ngẫu nhiên này.</div>
          <% } %>
          <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
          <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
          <form action="/tai-khoan/doi-mat-khau" method="post">
            <div class="field"><label>Mật khẩu hiện tại</label><input type="password" name="mat_khau_cu" required /></div>
            <div class="field"><label>Mật khẩu mới</label><input type="password" name="mat_khau_moi" required minlength="6" /></div>
            <div class="field"><label>Nhập lại mật khẩu mới</label><input type="password" name="mat_khau_moi_lai" required minlength="6" /></div>
            <button type="submit" class="btn btn-primary">Đổi mật khẩu</button>
          </form>
          <% if (pending) { %>
            <form action="/tai-khoan/doi-mat-khau/bo-qua" method="post" style="margin-top:10px;">
              <button type="submit" class="btn btn-outline btn-block">Bỏ qua, giữ mật khẩu ngẫu nhiên</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
