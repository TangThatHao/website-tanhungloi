<%- include('partials/header', { pageTitle: 'Tin tức - Tân Hưng Lợi', activeNav: 'news' }) %>

<div class="container">
  <div class="breadcrumb"><a href="/">Trang chủ</a> / Tin tức</div>
  <div class="page-body">
    <aside><%- include('partials/sidebar-left') %></aside>

    <main>
      <div class="section-title">Tin tức</div>
      <div class="box">
        <div class="box-body">
          <% newsItems.forEach(n => { %>
            <div class="news-list-item">
              <img src="<%= n.thumbnail %>" alt="<%= n.title %>" />
              <div>
                <h3><a href="/tin-tuc/<%= n.slug %>"><%= n.title %></a></h3>
                <p style="font-size:13px; color:var(--color-muted);"><%= n.summary %></p>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </main>

    <aside><%- include('partials/sidebar-right') %></aside>
  </div>
</div>

<%- include('partials/footer') %>
