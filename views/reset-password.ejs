<%- include('partials/header', { pageTitle: 'Đặt lại mật khẩu - Tân Hưng Lợi', activeNav: '' }) %>

<div class="container">
  <div class="form-box">
    <h2>ĐẶT LẠI MẬT KHẨU</h2>
    <% if (success) { %>
      <div class="alert alert-success">Đặt lại mật khẩu thành công. Bạn có thể đăng nhập bằng mật khẩu mới.</div>
      <div class="form-alt"><a href="/dang-nhap">Đăng nhập ngay →</a></div>
    <% } else if (!valid) { %>
      <div class="alert alert-error">Liên kết đặt lại mật khẩu không hợp lệ hoặc đã hết hạn.</div>
      <div class="form-alt"><a href="/quen-mat-khau">Yêu cầu liên kết mới</a></div>
    <% } else { %>
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <form action="/dat-lai-mat-khau/<%= token %>" method="post">
        <div class="field"><label>Mật khẩu mới</label><input type="password" name="mat_khau_moi" required minlength="6" /></div>
        <div class="field"><label>Nhập lại mật khẩu mới</label><input type="password" name="mat_khau_moi_lai" required minlength="6" /></div>
        <button type="submit" class="btn btn-primary btn-block">Đặt lại mật khẩu</button>
      </form>
    <% } %>
    <div class="form-alt"><a href="/dang-nhap">← Quay lại đăng nhập</a></div>
  </div>
</div>

<%- include('partials/footer') %>
